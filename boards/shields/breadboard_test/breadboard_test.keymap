#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/calc_keys.h>

/ {
    behaviors {
        calc: calc {
            compatible = "zmk,behavior-calc";
            #binding-cells = <1>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            /* ┌───────┬──────────┬────────────┬──────────┬───────┐
             * │ CALC  │    /     │     *      │   BKSP   │   %   │
             * ├───────┼──────────┼────────────┼──────────┼───────┤
             * │   7   │    8     │     9      │    -     │ NONE  │
             * ├───────┼──────────┼────────────┼──────────┼───────┤
             * │   4   │    5     │     6      │    +     │ NONE  │
             * ├───────┼──────────┼────────────┼──────────┼───────┤
             * │   1   │    2     │     3      │    =     │ NONE  │
             * ├───────┼──────────┼────────────┼──────────┼───────┤
             * │   0   │    .     │   NONE     │  ENTER   │ NONE  │
             * └───────┴──────────┴────────────┴──────────┴───────┘ */
            bindings = <
                &calc CALC_TOGGLE  &kp KP_SLASH  &kp KP_MULTIPLY  &kp BSPC      &kp PRCNT
                &kp KP_N7          &kp KP_N8     &kp KP_N9        &kp KP_MINUS  &none
                &kp KP_N4          &kp KP_N5     &kp KP_N6        &kp KP_PLUS   &none
                &kp KP_N1          &kp KP_N2     &kp KP_N3        &kp EQUAL     &none
                &kp KP_N0          &kp KP_DOT    &none            &kp KP_ENTER  &none
            >;
        };

        calculator_layer {
            /* ┌─────────┬──────────┬──────────┬──────────┬──────────┐
             * │  EXIT   │    ÷     │    ×     │   ←      │    %     │
             * ├─────────┼──────────┼──────────┼──────────┼──────────┤
             * │    7    │    8     │    9     │    -     │  NONE    │
             * ├─────────┼──────────┼──────────┼──────────┼──────────┤
             * │    4    │    5     │    6     │    +     │  NONE    │
             * ├─────────┼──────────┼──────────┼──────────┼──────────┤
             * │    1    │    2     │    3     │    =     │  NONE    │
             * ├─────────┼──────────┼──────────┼──────────┼──────────┤
             * │    0    │    .     │  NONE    │  CLEAR   │  NONE    │
             * └─────────┴──────────┴──────────┴──────────┴──────────┘ */
            bindings = <
                &calc CALC_TOGGLE   &calc CALC_OP_DIV  &calc CALC_OP_MUL  &calc CALC_BKSP    &calc CALC_OP_MOD
                &calc CALC_NUM_7    &calc CALC_NUM_8   &calc CALC_NUM_9   &calc CALC_OP_SUB  &none
                &calc CALC_NUM_4    &calc CALC_NUM_5   &calc CALC_NUM_6   &calc CALC_OP_ADD  &none
                &calc CALC_NUM_1    &calc CALC_NUM_2   &calc CALC_NUM_3   &calc CALC_EVAL    &none
                &calc CALC_NUM_0    &calc CALC_DOT     &none              &calc CALC_CLEAR   &none
            >;
        };
    };
};
